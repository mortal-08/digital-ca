{
  "name": "ca-web-pro-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "npm run dev --prefix \"CA web pro/backend\"",
    "frontend": "npm run dev --prefix \"CA web pro/frontend\"",
    "install-all": "npm install --prefix \"CA web pro/backend\" && npm install --prefix \"CA web pro/frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}